# LLM — DeepSeek drives the analysis step (tools/deepseek_analyze.py).
# ANTHROPIC_API_KEY is no longer used by the pipeline; kept here for back-compat only.
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# YouTube Data API v3 (Viral Video + YouTube AI Landscape sections)
YOUTUBE_API_KEY=

# RapidAPI — Instagram reel scraping (Viral Instagram Reels section).
# RAPIDAPI_KEY is your RapidAPI bearer token; HOST defaults to instagram-scraper-api2.
RAPIDAPI_KEY=8b21efe0-55fd-11f1-b09e-fff9962f73b1
RAPIDAPI_INSTAGRAM_HOST=instagram-scraper-api2.p.rapidapi.com

# Reddit read-only OAuth — "What People in AI Are Searching For" section.
# Optional: without these the trends scraper falls back to Reddit's anonymous
# JSON endpoint (lower rate limit). Google Trends + Hacker News need no keys.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-news-trends-bot/1.0

# LinkedIn (optional, fragile job source — laptop only)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# X / Twitter (optional, jobs)
X_BEARER_TOKEN=

# Slack (PDF DM + failure alerts)
SLACK_BOT_TOKEN=
SLACK_USER_ID=

# GitHub PAT for routine git push (repo scope)
GH_TOKEN=

# Recipient
USER_EMAIL=rahulmeenaailead@gmail.com

# Viral video thresholds — DEPRECATED. Pipeline now picks the max-views video
# in the last 24h with no view floor; these vars are ignored.
